# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transport_codex?schema=public"

# Environment
NODE_ENV="development"

# External integrations
ENABLE_EXTERNAL_GEOCODING="false"
ENABLE_EXTERNAL_ROUTING="false"
ENABLE_EXTERNAL_CURRENCY="false"
ENABLE_EXTERNAL_FUEL="false"

# Geocoding / Routing
NOMINATIM_ENDPOINT="https://nominatim.openstreetmap.org/search"
OSRM_ENDPOINT="https://router.project-osrm.org/route/v1/driving"
ROUTING_PROVIDER="ors-hgv"
ORS_HGV_ENDPOINT="https://api.openrouteservice.org/v2/directions/driving-hgv/geojson"
ORS_API_KEY=""

# Currency / Fuel
CURRENCY_API_ENDPOINT="https://api.nbp.pl/api/exchangerates/rates/A/EUR/?format=json"
CURRENCY_CACHE_TTL_MIN="720"
FUEL_CACHE_TTL_MIN="360"
FUEL_API_ENDPOINT=""

# HTTP client resilience
HTTP_TIMEOUT_MS="12000"
HTTP_RETRIES="1"

# Healthcheck
HEALTHCHECK_WITH_DB="false"
